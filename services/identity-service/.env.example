# Identity Service Configuration

# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://identity:password@localhost:5432/identitydb?schema=public"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=30d

# CORS
CORS_ORIGIN=*
