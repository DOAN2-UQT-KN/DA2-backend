<!DOCTYPE html>
<html>
  <body style="font-family: system-ui, sans-serif; line-height: 1.5; color: #111">
    <p>Hello,</p>
    <p>
      Please confirm the contact email for the organization
      <strong>{{organizationName}}</strong> on <strong>{{appName}}</strong>.
    </p>
    <p>
      <a href="{{verifyUrl}}" style="color: #0b57d0">Verify email address</a>
    </p>
    <p style="font-size: 0.875rem; color: #444">
      If the link does not work, copy and paste this URL into your browser:<br />
      {{verifyUrl}}
    </p>
    <p style="font-size: 0.875rem; color: #666">
      If you did not create this organization, you can ignore this message.
    </p>
  </body>
</html>
